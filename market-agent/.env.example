# --- Google / Gemini ---
GOOGLE_API_KEY=your-google-api-key
GEMINI_MODEL=gemini-3.5-flash

# --- MongoDB (workspace persistence) ---
MONGODB_URI=mongodb+srv://user:pass@cluster.example.mongodb.net/?appName=Cluster0
MONGODB_DATABASE=market_agent

# --- Phoenix (Arize track observability) ---
# Free account: https://app.phoenix.arize.com  (Settings -> API Keys)
PHOENIX_API_KEY=px_live_...
PHOENIX_COLLECTOR_ENDPOINT=https://app.phoenix.arize.com/s/your-space
PHOENIX_PROJECT_NAME=market-agent
